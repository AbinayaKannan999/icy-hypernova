# ==============================================
# FoodBridge V3 - Production Environment File
# Copy this to the ROOT of the project on AWS:
#   ~/icy-hypernova/.env
# ==============================================

# -------------------------
# Database (Docker service)
# -------------------------
DB_USER=postgres
DB_PASSWORD=CHANGE_TO_STRONG_PASSWORD
DB_NAME=foodbridge

# -------------------------
# JWT Authentication
# -------------------------
# IMPORTANT: Change this to a long random string (min 64 chars)
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_TO_LONG_RANDOM_STRING

# -------------------------
# URLs
# -------------------------
# Replace YOUR_EC2_PUBLIC_IP with your actual AWS IP (e.g. 3.87.123.456)
# Or use your domain if you have one (e.g. https://foodbridge.com)
FRONTEND_URL=http://YOUR_EC2_PUBLIC_IP

# -------------------------
# Email (Optional - for notifications)
# -------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=abinayakannan999@gmail.com
SMTP_PASS=YOUR_GMAIL_APP_PASSWORD
EMAIL_FROM=FoodBridge <noreply@foodbridge.com>

# -------------------------
# App Settings
# -------------------------
NODE_ENV=production
